        <update_date>2024-12-10</update_date>
        <experimental>False</experimental>
        <deprecated>False</deprecated>
        <tracker>https://github.com/pyarchinit/pyarchinit/issues</tracker>
        <repository>https://github.com/pyarchinit/pyarchinit</repository>
        <tags>archaeology,excavation,stratigraphy,harris matrix,database,gis,qgis</tags>
        <category>Database</category>
        <server>False</server>
    </pyqgis_plugin>

