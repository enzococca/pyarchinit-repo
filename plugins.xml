<plugins>
    <!-- ============================================ -->
    <!-- PyArchInit - Stable Release (Master Branch) -->
    <!-- ============================================ -->
    <pyqgis_plugin name="pyarchinit" version="4.0.0">
        <description><![CDATA[PyArchInit - Archaeological Data Management System for QGIS. Comprehensive tools for managing excavations, stratigraphic units, finds, and documentation.]]></description>
        <about><![CDATA[PyArchInit is a complete archaeological information system integrated with QGIS.

Features:
- Stratigraphic unit management (US/USM/WSU)
- Harris Matrix generation
- Finds inventory
- Burial records
- Period/Phase management
- PDF report generation
- Multi-database support (PostgreSQL/SQLite)

This is the STABLE version from the official repository.]]></about>
        <version>4.0.0</version>
        <qgis_minimum_version>3.22</qgis_minimum_version>
        <qgis_maximum_version>3.99</qgis_maximum_version>
        <homepage>https://github.com/pyarchinit/pyarchinit</homepage>
